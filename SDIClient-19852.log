<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Immobilien Darlehensrechner</title>
    <style>
        :root {
            --excel-green: #217346;
            --excel-light-green: #e8f5e9;
            --excel-yellow: #fff2cc;
        }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 20px; background-color: #f0f0f0; }
        .container { background: white; padding: 20px; border-radius: 4px; box-shadow: 0 0 10px rgba(0,0,0,0.1); max-width: 1200px; margin: auto; }
        
        h2 { color: var(--excel-green); border-bottom: 2px solid var(--excel-green); padding-bottom: 10px; }

        .input-section { display: flex; justify-content: flex-end; margin-bottom: 30px; }
        .input-table { border-collapse: collapse; }
        .input-table td { border: 1px solid #ccc; padding: 8px; }
        .label-cell { background-color: #f8f9fa; font-weight: bold; width: 180px; }
        .value-cell-yellow { background-color: var(--excel-yellow); width: 120px; text-align: right; }
        .value-cell-readonly { background-color: white; text-align: right; font-weight: bold; }
        
        input { border: none; background: transparent; text-align: right; width: 100%; font-size: 1rem; outline: none; }

        .calc-table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        .calc-table th { background-color: var(--excel-green); color: white; padding: 10px; border: 1px solid #fff; font-size: 0.85rem; }
        .calc-table td { border: 1px solid #ddd; padding: 8px; text-align: right; font-family: monospace; }
        .calc-table tr:nth-child(even) { background-color: #f9f9f9; }
        
        .footer-row { background-color: #eee !important; font-weight: bold; }
        .unit { font-size: 0.8rem; color: #666; margin-left: 4px; }
    </style>
</head>
<body>

<div class="container">
    <h2>Darlehensrechner</h2>

    <div class="input-section">
        <table class="input-table">
            <tr>
                <td class="label-cell">Darlehen</td>
                <td class="value-cell-yellow"><input type="number" id="darlehen" value="400000" oninput="calculate()"></td>
            </tr>
            <tr>
                <td class="label-cell">Rate (Jährlich)</td>
                <td class="value-cell-yellow"><input type="number" id="rateJahr" value="28800" oninput="calculate()"></td>
            </tr>
            <tr>
                <td class="label-cell">Zinssatz p.a. (%)</td>
                <td class="value-cell-yellow"><input type="number" id="zinsPa" value="3.9" step="0.01" oninput="calculate()"></td>
            </tr>
            <tr>
                <td class="label-cell">Dauer in Jahren</td>
                <td class="value-cell-yellow"><input type="number" id="dauer" value="20" oninput="calculate()"></td>
            </tr>
            <tr>
                <td class="label-cell">Darlehen + Zinsen</td>
                <td class="value-cell-readonly" id="gesamtKosten">0,00 €</td>
            </tr>
        </table>
    </div>

    <table class="calc-table">
        <thead>
            <tr>
                <th>Jahre</th>
                <th>Restschuld zu Anfang (€)</th>
                <th>Zins in € (p.a. * Restschuld)</th>
                <th>Tilgung in € (Rate - Zins)</th>
                <th>Rate in € (Formel)</th>
                <th>Restschuld Ende (€)</th>
            </tr>
        </thead>
        <tbody id="tableBody">
            </tbody>
        <tfoot>
            <tr class="footer-row">
                <td>Gesamt</td>
                <td>-</td>
                <td id="sumZins">0,00</td>
                <td id="sumTilgung">0,00</td>
                <td id="sumRate">0,00</td>
                <td>-</td>
            </tr>
        </tfoot>
    </table>
</div>

<script>
    function format(val) {
        return val.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function calculate() {
        const d_start = parseFloat(document.getElementById('darlehen').value) || 0;
        const r_jahr = parseFloat(document.getElementById('rateJahr').value) || 0;
        const z_pa = (parseFloat(document.getElementById('zinsPa').value) || 0) / 100;
        const jahre = parseInt(document.getElementById('dauer').value) || 1;

        let currentRestschuld = d_start;
        let tableHtml = "";
        
        let totalZins = 0;
        let totalTilgung = 0;
        let totalRate = 0;

        for (let i = 1; i <= jahre; i++) {
            let anfang = currentRestschuld;
            let zins = anfang * z_pa;
            let tilgung = r_jahr - zins;
            
            // Verhindern, dass mehr getilgt wird als Restschuld da ist
            if (tilgung > anfang) {
                tilgung = anfang;
            }
            
            let rate = zins + tilgung;
            let ende = anfang - tilgung;
            if (ende < 0.01) ende = 0;

            totalZins += zins;
            totalTilgung += tilgung;
            totalRate += rate;

            tableHtml += `
                <tr>
                    <td>${i}</td>
                    <td>${format(anfang)}</td>
                    <td>${format(zins)}</td>
                    <td>${format(tilgung)}</td>
                    <td>${format(rate)}</td>
                    <td>${format(ende)}</td>
                </tr>
            `;

            currentRestschuld = ende;
            if (currentRestschuld <= 0) break;
        }

        document.getElementById('tableBody').innerHTML = tableHtml;
        document.getElementById('sumZins').innerText = format(totalZins);
        document.getElementById('sumTilgung').innerText = format(totalTilgung);
        document.getElementById('sumRate').innerText = format(totalRate);
        document.getElementById('gesamtKosten').innerText = format(totalRate) + " €";
    }

    // Erstberechnung beim Laden
    calculate();
</script>

</body>
</html>